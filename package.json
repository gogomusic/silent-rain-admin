{
  "name": "silent-rain-admin",
  "version": "1.0.0",
  "private": true,
  "description": "「静夜聆雨」网站管理后台",
  "repository": {
    "type": "git",
    "url": "https://github.com/gogomusic/silent-rain-admin.git"
  },
  "scripts": {
    "analyze": "cross-env ANALYZE=1 max build",
    "dev": "cross-env UMI_ENV=dev max dev",
    "dev:prod": "cross-env UMI_ENV=prod max dev",
    "build": "max build",
    "i18n-remove": "node scripts/i18n-remove.js",
    "lint": "npm run biome:lint && npm run tsc",
    "biome:lint": "biome lint",
    "biome": "biome check --write",
    "openapi": "max openapi",
    "prepare": "npx husky && max setup",
    "preview": "max preview --port 8000",
    "preview:build": "max build && max preview --port 8000",
    "doctor": "react-doctor .",
    "tsc": "tsc --noEmit"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@ant-design/pro-components": "3.1.12-0",
    "@ant-design/x": "^2.8.0",
    "@ant-design/x-markdown": "^2.8.0",
    "@ant-design/x-sdk": "^2.8.0",
    "@enum-plus/plugin-antd": "^1.0.0",
    "@microlink/react-json-view": "^1.31.20",
    "@tanstack/react-query": "^5.101.0",
    "antd": "^6.4.4",
    "antd-img-crop": "^4.30.0",
    "antd-style": "^4.1.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "enum-plus": "^3.1.8",
    "highlight.js": "^11.11.1",
    "lodash": "^4.18.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@ant-design/cli": "^6.4.4",
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@umijs/max": "^4.6.63",
    "@umijs/max-plugin-openapi": "^2.0.3",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "less-loader": "12.0.0",
    "lint-staged": "^17.0.7",
    "react-doctor": "^0.5.6",
    "swagger-ui-dist": "^5.32.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css}": [
      "biome check --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "create-umi": {
    "ignoreScript": [
      "docker*",
      "functions*",
      "site",
      "generateMock"
    ],
    "ignoreDependencies": [
      "netlify*",
      "serverless"
    ],
    "ignore": [
      ".dockerignore",
      ".git",
      ".github",
      ".gitpod.yml",
      "CODE_OF_CONDUCT.md",
      "Dockerfile",
      "Dockerfile.*",
      "lambda",
      "LICENSE",
      "netlify.toml",
      "README.*.md",
      "azure-pipelines.yml",
      "docker",
      "CNAME",
      "create-umi"
    ]
  }
}
